# API
PORT=3000
FRONTEND_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reader_dev
JWT_SECRET=
LOG_LEVEL=info

# Auth
# Google OAuth is required in production. Local development can use /api/auth/dev.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME=Dev User

# Book processing
BOOK_PROCESSING_RUNNER_ENABLED=true
BOOK_PROCESSING_MAX_ATTEMPTS=3
BOOK_PROCESSING_POLL_INTERVAL_MS=2000
BOOK_PROCESSING_RETRY_DELAY_MS=5000
BOOK_PROCESSING_STALE_LOCK_MS=900000

# OpenAI and vector search
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
VECTOR_STORE_DRIVER=pg

# Legacy Chroma support. Required only when VECTOR_STORE_DRIVER=chroma.
CHROMA_URL=http://localhost:8000
CHROMA_CLIENT_AUTH_CREDENTIALS=

# Legacy Redis/BullMQ worker support. Required only when running apps/worker.
REDIS_URL=redis://localhost:6379

# Book file storage
# Use local storage for local development. Use s3 in production.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=.local-storage

# S3 storage. Required only when STORAGE_DRIVER=s3.
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_REGION=us-east-1

# Optional local AWS SDK credentials. Lightsail production uses scoped S3 keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Langfuse observability. Leave keys empty to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_SAMPLE_RATE=1
LANGFUSE_CAPTURE_CONTENT=metadata
LANGFUSE_MAX_CAPTURE_CHARS=500

# Vector ingestion tuning
VECTOR_STORE_BATCH_SIZE=50
VECTOR_STORE_CONCURRENT_BATCHES=2
VECTOR_STORE_BATCH_RETRY_ATTEMPTS=4
VECTOR_STORE_BATCH_RETRY_DELAY_MS=1000
