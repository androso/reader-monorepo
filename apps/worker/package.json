{
    "name": "@reader/worker",
    "version": "0.1.0",
    "private": true,
    "main": "build/apps/worker/src/index.js",
    "scripts": {
        "predev": "pnpm --filter @reader/jobs --filter @reader/providers --filter @reader/epub --filter @reader/processing build",
        "prebuild": "pnpm --filter @reader/jobs --filter @reader/providers --filter @reader/epub --filter @reader/processing build",
        "dev": "DOTENV_CONFIG_PATH=../../.env ts-node-dev -r dotenv/config --respawn --transpile-only --ignore-watch ../../packages src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config build/apps/worker/src/index.js",
        "pretest": "pnpm --filter @reader/jobs --filter @reader/processing build",
        "test": "tsc -p tsconfig.test.json && node --test ../../.tmp/apps-worker-test/test/worker.test.js"
    },
    "dependencies": {
        "@reader/jobs": "workspace:*",
        "@reader/processing": "workspace:*",
        "bullmq": "^5.64.1",
        "dotenv": "^16.4.7",
        "drizzle-orm": "^0.38.3",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "typescript": "^5.7.2"
    }
}
