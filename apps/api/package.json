{
    "name": "@reader/api",
    "version": "1.0.0",
    "private": true,
    "main": "build/index.js",
    "scripts": {
        "predev": "pnpm --filter @reader/processing --filter @reader/providers build",
        "prebuild": "pnpm --filter @reader/processing --filter @reader/providers build",
        "pretest": "pnpm --filter @reader/processing --filter @reader/providers build",
        "dev": "DOTENV_CONFIG_PATH=../../.env ts-node-dev -r dotenv/config --respawn --transpile-only --ignore-watch ../../packages src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config build/index.js",
        "test": "tsc -p tsconfig.test.json && NODE_PATH=./node_modules:../../packages/processing/node_modules node --test ../../.tmp/apps-api-test/test/*.js"
    },
    "dependencies": {
        "@reader/processing": "workspace:*",
        "@reader/providers": "workspace:*",
        "@aws-sdk/client-s3": "^3.723.0",
        "@neondatabase/serverless": "^0.10.4",
        "@types/cors": "^2.8.17",
        "@types/dotenv": "^8.2.3",
        "@types/epub": "^0.2.0",
        "@types/express": "^5.0.0",
        "@types/jsdom": "^21.1.7",
        "@types/node": "^22.10.2",
        "@types/xml2js": "^0.4.14",
        "chromadb": "^1.9.4",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.4.7",
        "drizzle-kit": "^0.30.1",
        "drizzle-orm": "^0.38.3",
        "epub": "^1.2.1",
        "express": "^4.21.2",
        "google-auth-library": "^9.15.0",
        "jsdom": "^25.0.1",
        "jsonwebtoken": "^9.0.2",
        "jszip": "^3.10.1",
        "multer": "^1.4.5-lts.1",
        "minisearch": "^7.1.2",
        "openai": "^4.77.0",
        "pdf2json": "^3.1.5",
        "pg": "^8.21.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.2",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.12",
        "@types/pg": "^8.20.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.7",
        "husky": "^9.1.7",
        "lint-staged": "^15.3.0",
        "prettier": "^3.4.2"
    }
}
