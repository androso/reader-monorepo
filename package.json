{
    "name": "reader-platform",
    "version": "1.0.0",
    "private": true,
    "description": "Reader platform monorepo",
    "scripts": {
        "dev": "pnpm --filter @reader/api dev",
        "build": "pnpm --filter @reader/api build",
        "test": "pnpm --filter @reader/api test",
        "api:dev": "pnpm --filter @reader/api dev",
        "api:build": "pnpm --filter @reader/api build",
        "web:dev": "pnpm --filter @reader/web dev",
        "web:build": "pnpm --filter @reader/web build",
        "web:start": "pnpm --filter @reader/web start",
        "web:lint": "pnpm --filter @reader/web lint",
        "prepare": "husky install"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^15.3.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.2"
    },
    "lint-staged": {
        "*.{js,css,md}": "prettier --write"
    },
    "packageManager": "pnpm@10.11.1"
}
