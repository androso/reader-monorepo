READER_DOMAIN=reader.example.com

POSTGRES_USER=reader
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=reader

JWT_SECRET=change-me-long-random-secret
FRONTEND_URL=https://reader.example.com
API_PORT=3000
WEB_PORT=3001
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
VECTOR_STORE_BATCH_SIZE=25
VECTOR_STORE_BATCH_RETRY_ATTEMPTS=4
VECTOR_STORE_BATCH_RETRY_DELAY_MS=1000

STORAGE_DRIVER=s3
S3_REGION=us-east-1
S3_BUCKET_NAME=your-reader-bucket
AWS_ACCESS_KEY_ID=your-s3-access-key
AWS_SECRET_ACCESS_KEY=your-s3-secret-key

BOOK_PROCESSING_RUNNER_ENABLED=true
BOOK_PROCESSING_MAX_ATTEMPTS=3
BOOK_PROCESSING_POLL_INTERVAL_MS=2000
BOOK_PROCESSING_RETRY_DELAY_MS=5000
BOOK_PROCESSING_STALE_LOCK_MS=900000
